" \d: 打开/关闭目录树
nmap <Leader>d :NERDTreeToggle<CR>

" NERDTree配置
let g:NERDTreeWinPos = "right"       " 显示在右侧
let g:NERDTreeWinSize = 35           " 窗口宽度
let g:NERDTreeShowHidden = 1         " 显示隐藏文件
let g:NERDTreeMinimalUI = 1          " 简洁界面
